{
  "layer": "top",
  "position": "top",
  "height": 34,
  "modules-left": [
    "custom/dragon",
    "hyprland/workspaces",
    "hyprland/window"
  ],
  "modules-right": [
    "tray",
    "pulseaudio",
    "network",
    "cpu",
    "memory",
    "clock",
    "custom/fox"
  ],
  "hyprland/workspaces": {
    "format": "{icon}",
    "on-click": "activate"
  },
  "custom/dragon": {
    "format": " ",
    "tooltip": false,
    "on-click": "wofi --show drun"
  },
  "custom/fox": {
    "format": "🦊",
    "tooltip": false,
    "on-click": "kitty -e htop",
    "on-click-right": "wlogout"
  },
  "cpu": {
    "interval": 10,
    "format": "  {usage}%",
    "max-length": 10
  },
  "memory": {
    "interval": 30,
    "format": "  {}%",
    "max-length": 10,
    "tooltip-format": "Memória: {used:0.1f}GB / {total:0.1f}GB"
  },
  "clock": {
    "format": " {:%H:%M}",
    "tooltip-format": "<tt><small>{calendar}</small></tt>",
    "calendar": {
      "mode": "month",
      "mode-mon-col": 3,
      "on-scroll": 1,
      "format": {
        "months": "<span color='#7a5ccc'><b>{}</b></span>",
        "days": "<span color='#cdd6f4'><b>{}</b></span>",
        "weekdays": "<span color='#b3aee5'><b>{}</b></span>",
        "today": "<span color='#7a5ccc'><b><u>{}</u></b></span>"
      }
    },
    "actions": {
      "on-click-right": "mode",
      "on-scroll-up": "shift_up",
      "on-scroll-down": "shift_down"
    }
  },
  "tray": {
    "icon-size": 21,
    "spacing": 10
  },
  "pulseaudio": {
    "format": "{icon} {volume}%",
    "format-bluetooth": "{icon} {volume}%",
    "format-muted": "󰝟 Mute",
    "on-click": "pavucontrol",
    "format-icons": {
      "headphone": " ",
      "headset": " ",
      "phone": " ",
      "portable": " ",
      "car": " ",
      "default": [
        "󰕾 ",
        "󰕾 ",
        "󰕾 "
      ]
    }
  },
  "network": {
    "format-ethernet": "󰄄  {ifname}",
    "format-linked": "󰄄  {ifname} (No IP)",
    "format-disconnected": "󰮞 Disconnected",
    "tooltip-format": "IP: {ipaddr}\n↑ {bandwidthUpBits} ↓ {bandwidthDownBits}"
  }
}
